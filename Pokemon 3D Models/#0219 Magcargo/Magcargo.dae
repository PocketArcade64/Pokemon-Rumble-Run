            </node>
            <node id="merged_1_0_node" sid="merged_1_0_node" name="merged_1_0_node">
                <instance_controller url="#merged_1_0_node-controller">
                    <skeleton>#ROOT</skeleton>
                    <bind_material>
                        <technique_common>
                            <instance_material target="#mat_body_mat_id" symbol="mat_body_mat_id" />
