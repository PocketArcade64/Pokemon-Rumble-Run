        <effect id="TEX_ANIM_EYE_mat_id-effect" name="TEX_ANIM_EYE_mat_id">
            <profile_COMMON>
                <newparam sid="-image_surface">
                    <surface type="2D">
                        <init_from>-image</init_from>
                    </surface>
                </newparam>
                <newparam sid="-image_sampler">
                    <sampler2D>
                        <source>-image_surface</source>
                    </sampler2D>
                </newparam>
                <technique sid="standard">
                    <phong>
                        <emission>
                            <color sid="emission">0 0 0 1</color>
                        </emission>
                        <ambient>
                            <color sid="ambient">1 1 1 1</color>
                        </ambient>
                        <diffuse>
