    <effect id="TEX_ANIM_EYE_eff_id" name="TEX_ANIM_EYE_eff">
      <profile_COMMON>
        <newparam sid="TEX_ANIM_EYE_surf">
          <surface type="2D">
            <init_from>Pii_ANNOON_eye</init_from>
            <format>PNG</format>
          </surface>
        </newparam>
        <newparam sid="TEX_ANIM_EYE_samp">
          <sampler2D>
            <source>TEX_ANIM_EYE_surf</source>
            <wrap_s>WRAP</wrap_s>
            <wrap_t>WRAP</wrap_t>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
            <mipfilter>LINEAR</mipfilter>
          </sampler2D>
        </newparam>
        <technique sid="TEX_ANIM_EYE_tech">
          <phong>
            <diffuse>
              <texture texture="TEX_ANIM_EYE_samp" texcoord="uv" />
            </diffuse>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
