                    <surface type="2D">
                        <init_from>-image</init_from>
                    </surface>
                </newparam>
                <newparam sid="-image_sampler">
                    <sampler2D>
                        <source>-image_surface</source>
                        <wrap_s>CLAMP</wrap_s>
                    </sampler2D>
                </newparam>
                <technique sid="standard">
                    <phong>
                        <emission>
                            <color sid="emission">0 0 0 1</color>
                        </emission>
                        <ambient>
                            <color sid="ambient">1 1 1 1</color>
                        </ambient>
                        <diffuse>
                            <texture texture="-image_sampler" texcoord="CHANNEL0" />
                        </diffuse>
                        <specular>
