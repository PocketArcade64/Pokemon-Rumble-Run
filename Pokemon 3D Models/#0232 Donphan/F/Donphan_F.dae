    <library_effects>
        <effect id="TEX_ANIM_EYE_mat_id-effect" name="TEX_ANIM_EYE_mat_id">
            <profile_COMMON>
                <newparam sid="-image_surface">
                    <surface type="2D">
                        <init_from>-image</init_from>
                    </surface>
                </newparam>
                <newparam sid="-image_sampler">
                    <sampler2D>
                        <source>-image_surface</source>
                        <wrap_s>CLAMP</wrap_s>
                    </sampler2D>
                </newparam>
                <technique sid="standard">
                    <phong>
                        <emission>
                            <color sid="emission">0 0 0 1</color>
                        </emission>
                        <ambient>
                            <color sid="ambient">1 1 1 1</color>
                        </ambient>
                        <diffuse>
                            <texture texture="-image_sampler" texcoord="CHANNEL0" />
                        </diffuse>
                        <specular>
                            <color sid="specular">0.5 0.5 0.5 1</color>
                        </specular>
                        <reflective>
                            <color sid="reflective">1 1 1 1</color>
                        </reflective>
                        <shininess>
                            <float sid="shininess">50</float>
                        </shininess>
                        <reflectivity>
                            <float sid="reflectivity">1</float>
                        </reflectivity>
                        <transparency>
                            <float sid="transparency">1</float>
                        </transparency>
                    </phong>
                </technique>
            </profile_COMMON>
        </effect>
